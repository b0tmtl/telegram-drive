{
  "name": "telegram-drive",
  "version": "1.0.0",
  "description": "Telegram as a personal file drive with automatic chunking for large files",
  "main": "main/index.js",
  "scripts": {
    "start": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:renderer": "cd renderer && npm run dev",
    "build:renderer": "cd renderer && npm run build",
    "build": "npm run build:renderer && electron-builder",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:win": "npm run build:renderer && electron-builder --win",
    "pack": "npm run build:renderer && electron-builder --dir"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "telegram": "^2.26.10",
    "keytar": "^7.9.0",
    "big-integer": "^1.6.52"
  },
  "build": {
    "appId": "com.telegramdrive.app",
    "productName": "Telegram Drive",
    "files": [
      "main/**/*",
      "renderer/dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
